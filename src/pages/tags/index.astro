---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/astro/Header.astro";
import Footer from "../../components/astro/Footer.astro";

const allPosts = await getCollection("blog");
const publishedPosts = allPosts.filter((post) => !post.data.draft);

const tagMap = new Map<string, number>();
publishedPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  });
});

const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const STAGGER_MS = Math.min(30, tags.length > 0 ? 900 / tags.length : 30);

const siteTitle = "Tags - ywc.life";
const siteDescription = "태그별로 포스트를 탐색해 보세요.";
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <section class="text-center mb-12">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-gray-900">Tags</h1>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            총 <span class="text-gray-900 font-semibold">{tags.length}</span>개의 태그가 있어요.
          </p>
        </section>

        <section class="max-w-2xl mx-auto" aria-label="태그 목록">
          <ul class="flex flex-col">
            {
              tags.map((tag, i) => {
                const delay = Math.round(i * STAGGER_MS);
                return (
                  <li class="tag-row" style={`--stagger: ${delay}ms;`}>
                    <a
                      href={`/tags/${tag.name.toLowerCase()}`}
                      class="group flex items-center gap-3 py-2.5 px-3 rounded-md no-underline transition-colors duration-150 hover:bg-gray-50 focus-visible:outline-none focus-visible:bg-gray-50 focus-visible:ring-2 focus-visible:ring-blue-500"
                      aria-label={`${tag.name} 태그, 포스트 ${tag.count}개`}
                    >
                      <span class="text-gray-900 font-medium text-base">{tag.name}</span>
                      <span
                        class="flex-1 h-0 border-b-2 border-dotted border-gray-300 group-hover:border-gray-400 transition-colors"
                        aria-hidden="true"
                      />
                      <span class="text-gray-500 text-sm tabular-nums min-w-[2ch] text-right">
                        {tag.count}
                      </span>
                      <span
                        class="inline-block w-4 text-gray-400 text-sm opacity-0 -translate-x-1 transition-all duration-150 group-hover:opacity-100 group-hover:translate-x-0 group-focus-visible:opacity-100 group-focus-visible:translate-x-0"
                        aria-hidden="true"
                      >
                        →
                      </span>
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </section>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  @keyframes tag-row-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tag-row {
    animation: tag-row-in 400ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: var(--stagger, 0ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .tag-row {
      animation: none;
    }
  }
</style>
