---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/astro/Header.astro";
import Footer from "../../components/astro/Footer.astro";
import categoriesData from "../../content/categories.json";

const allPosts = await getCollection("blog");
const publishedPosts = allPosts.filter((post) => !post.data.draft);

const categories = categoriesData.map((cat) => ({
  ...cat,
  count: publishedPosts.filter((p) => p.data.category === cat.name).length,
}));

const siteTitle = "Categories - ywc.life";
const siteDescription = "카테고리별로 포스트를 탐색해 보세요.";

const breadcrumb = [
  { name: "홈", url: "https://ywc.life" },
  { name: "카테고리", url: "https://ywc.life/categories" },
];
---

<BaseLayout title={siteTitle} description={siteDescription} breadcrumb={breadcrumb}>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <section class="text-center mb-16">
          <h1 class="text-4xl sm:text-5xl font-bold mb-4 text-gray-900">Categories</h1>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            관심 있는 주제를 카테고리로 골라 보세요.
          </p>
        </section>

        <section class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {
            categories.map((cat) => (
              <a
                href={`/categories/${cat.slug}`}
                class="block border border-gray-200 rounded-xl p-6 bg-white hover:border-blue-300 hover:shadow-md transition-all"
              >
                <div class="flex items-center justify-between mb-3">
                  <h2 class="text-xl font-bold text-gray-900">{cat.name}</h2>
                  <span class="px-2.5 py-0.5 text-xs rounded-full bg-blue-100 text-blue-800">
                    {cat.count}
                  </span>
                </div>
                <p class="text-gray-600 text-sm">{cat.description}</p>
              </a>
            ))
          }
        </section>
      </div>
    </main>

    <Footer />
  </div>
</BaseLayout>
